<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="☰"
            android:textColor="@color/text_main"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:spacing="16dp">

            <TextView
                android:id="@+id/icon_turn_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="⬅️"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/icon_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="💡"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/icon_turn_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➡️"
                android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/icon_signal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="📶"
            android:textColor="@color/text_main"
            android:textSize="20sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <TextView
            android:id="@+id/tv_connection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/icon_signal"
            android:text="● Connected"
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:layout_alignParentEnd="true"/>

        <TextView
            android:id="@+id/tv_bike_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DTC-Bike"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_bike_model"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="S1"
            android:textColor="@color/text_sub"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_bike_fw"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="FW: v1.0.2"
            android:textColor="@color/text_sub"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
    android:id="@+id/status_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingTop="8dp"
    android:weightSum="3"
    app:layout_constraintTop_toBottomOf="@id/info_bar">

    <!-- PIN -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_weight="1"
        android:layout_margin="4dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/card_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:text="PIN"
                android:textSize="10sp"
                android:textColor="@color/text_sub"/>

            <TextView
                android:id="@+id/tv_battery"
                android:text="85%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"/>
        </LinearLayout>
      
        <LinearLayout
    android:layout_weight="1"
    android:orientation="vertical"
    android:gravity="end">

    <TextView
        android:text="RANGE"
        android:textSize="10sp"
        android:textColor="@color/text_sub"/>

    <TextView
        android:id="@+id/tv_est_range"
        android:text="120 km"
        android:textSize="20sp"
        android:textStyle="bold"/>

<SeekBar
    android:id="@+id/seek_regen"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:max="3"
    android:progress="1"/>

<TextView
    android:id="@+id/tv_regen"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Regen: 1"
    android:textColor="@color/text_main"/>

     <TextView
    android:id="@+id/tv_connection"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_below="@id/icon_signal"
    android:text="● Connected"
    android:textColor="@color/accent_green"
    android:textSize="12sp"
    android:layout_alignParentEnd="true"/>
</LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- MODE -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_weight="1"
        android:layout_margin="4dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/card_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:text="MODE"
                android:textSize="10sp"
                android:textColor="@color/text_sub"/>

            <TextView
                android:id="@+id/tv_drive_mode"
                android:text="D"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/accent_cyan"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- RANGE -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_weight="1"
        android:layout_margin="4dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/card_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:text="RANGE"
                android:textSize="10sp"
                android:textColor="@color/text_sub"/>

            <TextView
                android:id="@+id/tv_est_range"
                android:text="120 km"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>

    <FrameLayout
    android:id="@+id/center_speed_area"
    android:layout_width="280dp"
    android:layout_height="280dp"
    android:layout_marginTop="20dp"
    app:layout_constraintTop_toBottomOf="@id/status_bar"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <!-- vòng ngoài -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_speed_circle"/>

    <!-- nội dung -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_speed"
            android:text="65"
            android:textSize="95sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"/>

        <TextView
            android:text="km/h"
            android:textColor="@color/text_sub"/>

        <TextView
            android:id="@+id/tv_gps_speed"
            android:text="GPS: 64"
            android:textSize="14sp"
            android:textColor="@color/accent_cyan"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</FrameLayout>

    <LinearLayout
        android:id="@+id/action_buttons_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center|top"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="16dp" 
        app:layout_constraintTop_toBottomOf="@id/center_speed_area"
        app:layout_constraintBottom_toTopOf="@id/bottom_card"
        app:layout_constraintVertical_bias="0.75" 
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_lock"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/lock" 
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                app:tint="@color/text_main" />

            <TextView
                android:id="@+id/tv_label_function"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Kết nối"
                android:textColor="@color/text_main"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_find"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/find"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                app:tint="@color/text_main" />

            <TextView
                android:id="@+id/tv_label_find"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tìm xe"
                android:textColor="@color/text_sub"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_advanced"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/advanced"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                app:tint="@color/text_main" />

            <TextView
                android:id="@+id/tv_label_advanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Nâng cao"
                android:textColor="@color/text_sub"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/btn_history"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/history"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                app:tint="@color/text_main" />

            <TextView
                android:id="@+id/tv_label_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Lịch sử"
                android:textColor="@color/text_sub"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:id="@+id/bottom_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"> <TextView
                    android:id="@+id/tv_odo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ODO: 1250"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_cycles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="CK: 36"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_voltage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Pin: 72.4 V"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btn_tech_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="⚙️"
                    android:textSize="18sp"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="8dp" android:background="@color/divider_color"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_temp_bms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BMS: 35°C"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_temp_fet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FET: 40°C"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_temp_motor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Motor: 45°C"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_temp_acu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ACU: 38°C"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="8dp" android:background="@color/divider_color"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_temp_pin1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pin1: 32°"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tv_temp_pin2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pin2: 33°"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tv_temp_pin3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pin3: 31°"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tv_temp_pin4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pin4: 32°"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="8dp" android:background="@color/divider_color"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_cell_diff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lệch: 0.005 V"
                    android:textColor="@color/accent_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_vmin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Vmin: 3.210 V"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tv_vmax"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Vmax: 3.215 V"
                    android:textColor="@color/text_main"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>